<script>
  document.addEventListener('astro:page-load', () => {
    // --- Tilt Cards ---
    const tiltCards = document.querySelectorAll('.tilt-card');
    tiltCards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const xRot = 15 * ((y - rect.height / 2) / (rect.height / 2));
        const yRot = -15 * ((x - rect.width / 2) / (rect.width / 2));
        card.style.transform = `perspective(1000px) rotateX(${xRot}deg) rotateY(${yRot}deg) scale3d(1.02, 1.02, 1.02)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = `perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)`;
      });
    });

    // --- Mobile Menu ---
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    
    if (mobileMenuBtn && mobileMenu) {
      let menuOpen = false;
      mobileMenuBtn.addEventListener('click', () => {
        menuOpen = !menuOpen;
        if (menuOpen) {
          mobileMenu.classList.remove('hidden');
          mobileMenu.classList.add('flex');
          document.body.style.overflow = 'hidden';
        } else {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
          document.body.style.overflow = '';
        }
      });
      
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          menuOpen = false;
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
          document.body.style.overflow = '';
        });
      });
    }

    // --- Hover Reveal (desktop only) ---
    const revealRows = document.querySelectorAll('.hover-reveal-row');
    const follower = document.getElementById('hover-follower');
    const isTouchDevice = ('ontouchstart' in window) || navigator.maxTouchPoints > 0;

    let followerX = window.innerWidth / 2;
    let followerY = window.innerHeight / 2;
    let targetX = followerX;
    let targetY = followerY;
    let isTracking = false;

    if (follower && !isTouchDevice) {
      document.addEventListener('mousemove', (e) => {
        targetX = e.clientX;
        targetY = e.clientY;
        if (!isTracking) {
          followerX = targetX;
          followerY = targetY;
          isTracking = true;
        }
      });

      revealRows.forEach(row => {
        row.addEventListener('mouseenter', () => {
          const rowId = row.getAttribute('data-id');
          document.querySelectorAll('[id^="reveal-img-"]').forEach(el => {
            el.style.opacity = '0';
            el.style.transform = 'translate(-50%, -50%) scale(0.5) rotate(0deg)';
          });
          if (rowId) {
            const activeImg = document.getElementById(`reveal-img-${rowId}`);
            if (activeImg) {
              activeImg.style.opacity = '1';
              activeImg.style.transform = `translate(-50%, -50%) scale(1) rotate(${(Math.random() - 0.5) * 6}deg)`;
            }
          }
        });
        row.addEventListener('mouseleave', () => {
          const rowId = row.getAttribute('data-id');
          if (rowId) {
            const activeImg = document.getElementById(`reveal-img-${rowId}`);
            if (activeImg) {
              activeImg.style.opacity = '0';
              activeImg.style.transform = 'translate(-50%, -50%) scale(0.5) rotate(0deg)';
            }
          }
        });
      });
    }

    // --- Intersection Observer ---
    const observerOptions = { root: null, rootMargin: '0px', threshold: 0.1 };
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);
    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));

    // --- CTA Animation on Scroll ---
    const ctaSection = document.getElementById('contact');
    const ctaContent = document.querySelector('.cta-content');
    const ctaObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          ctaContent?.classList.add('cta-animate');
          ctaObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    if (ctaSection) ctaObserver.observe(ctaSection);

    // --- Scroll Elements ---
    const journey = document.getElementById('apple-journey');
    const expandBg = document.querySelector('.expand-bg-element');
    const frame1 = document.querySelector('.frame-1');
    const frame2 = document.querySelector('.frame-2');
    const frame3 = document.querySelector('.frame-3');
    const card1 = document.querySelector('.ui-card-1');
    const card2 = document.querySelector('.ui-card-2');
    const particleSlow = document.querySelector('.scroll-spin-particle-slow');
    const particleFast = document.querySelector('.scroll-spin-particle-fast');
    const particleCore = document.querySelector('.scroll-spin-particle-core');
    const horizontalSection = document.getElementById('work');
    const horizontalTrack = document.querySelector('.horizontal-track');
    // --- Canvas Particles ---
    const canvas = document.getElementById('cta-particles');
    const ctaContactSection = document.getElementById('contact');
    let particlesVisible = false;
    if (canvas && ctaContactSection) {
      new IntersectionObserver(
        ([entry]) => {
          const wasVisible = particlesVisible;
          particlesVisible = entry.isIntersecting;
          if (particlesVisible && !wasVisible) renderParticles();
        },
        { threshold: 0 }
      ).observe(ctaContactSection);

      const ctx = canvas.getContext('2d');
      if (ctx) {
        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;

        window.addEventListener('resize', () => {
          width = canvas.width = window.innerWidth;
          height = canvas.height = window.innerHeight;
        }, { passive: true });

        const particles = [];
        const particleCount = window.innerWidth > 768 ? 120 : 60;
        for (let i = 0; i < particleCount; i++) {
          particles.push({
            x: Math.random() * width,
            y: Math.random() * height,
            vx: (Math.random() - 0.5) * 0.3,
            vy: (Math.random() - 0.5) * 0.3,
            size: Math.random() * 2 + 0.5,
            color: Math.random() > 0.5 ? '#22d3ee' : '#a78bfa',
            alpha: Math.random() * 0.25 + 0.1
          });
        }

        let mouse = { x: -1000, y: -1000, active: false, radius: 150 };
        
        ctaContactSection.addEventListener('mousemove', (e) => {
          const rect = ctaContactSection.getBoundingClientRect();
          mouse.x = e.clientX - rect.left;
          mouse.y = e.clientY - rect.top;
          mouse.active = true;
        });

        ctaContactSection.addEventListener('mouseleave', () => {
          mouse.active = false;
        });

        function renderParticles() {
          ctx.clearRect(0, 0, width, height);
          ctx.globalCompositeOperation = 'screen';
          for (let i = 0; i < particles.length; i++) {
            const p = particles[i];
            
            if (mouse.active) {
              const dx = mouse.x - p.x;
              const dy = mouse.y - p.y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < mouse.radius) {
                const force = (mouse.radius - dist) / mouse.radius;
                p.x -= (dx / dist) * force * 4;
                p.y -= (dy / dist) * force * 4;
              }
            }
            
            p.x += p.vx;
            p.y += p.vy;
            if (p.x < 0) p.x = width;
            else if (p.x > width) p.x = 0;
            if (p.y < 0) p.y = height;
            else if (p.y > height) p.y = 0;
            
            p.vx *= 0.99;
            p.vy *= 0.99;
            p.vx += (Math.random() - 0.5) * 0.05;
            p.vy += (Math.random() - 0.5) * 0.05;
            
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx.fillStyle = p.color;
            ctx.globalAlpha = p.alpha;
            ctx.fill();
          }
          ctx.globalAlpha = 1.0;
          if (particlesVisible && document.visibilityState === 'visible') requestAnimationFrame(renderParticles);
        }
        renderParticles();
      }
    }

    // Cache journey offset once (avoids getBoundingClientRect in RAF)
    let journeyTop = 0;
    let journeyHeight = 0;
    function updateJourneyBounds() {
      if (journey) {
        journeyTop = journey.offsetTop;
        journeyHeight = journey.offsetHeight;
      }
    }
    updateJourneyBounds();
    window.addEventListener('resize', updateJourneyBounds, { passive: true });

    // --- UNIFIED RAF LOOP ---
    function render() {
      const scrollY = window.scrollY;

      // Spin Particles
      if (particleSlow) particleSlow.style.transform = `translate(-50%, -50%) rotate(${scrollY * 0.05}deg)`;
      if (particleFast) particleFast.style.transform = `translate(-50%, -50%) rotate(${-scrollY * 0.15}deg)`;
      if (particleCore) particleCore.style.transform = `translate(-50%, -50%) rotate(${scrollY * 0.1}deg) scale(${1 + Math.sin(scrollY * 0.005) * 0.05})`;

      // Journey Animations
      if (journey) {
        const ih = window.innerHeight;
        let p = (scrollY - journeyTop) / (journeyHeight - ih);
        p = Math.max(0, Math.min(1, p));

        if (expandBg) {
          if (p < 0.4) {
            expandBg.style.opacity = `${p * 5}`;
            const scaleAmount = 0.1 + p * 2.25;
            expandBg.style.transform = `translate(-50%, -50%) scale(${scaleAmount})`;
          } else {
            expandBg.style.transform = `translate(-50%, -50%) scale(1)`;
            expandBg.style.opacity = '1';
          }
        }

        if (frame1) {
          let f1Opacity = Math.max(0, Math.min(1, 1 - (p - 0.05) * 6));
          frame1.style.opacity = p < 0.05 ? '1' : `${f1Opacity}`;
          frame1.style.transform = `translateY(${p * -200}px) scale(${1 + p * 0.5})`;
        }

        if (frame2 && card1 && card2) {
          let f2Opacity = 0;
          if (p > 0.2 && p < 0.7) {
            f2Opacity = p < 0.4 ? (p - 0.2) * 5 : (p > 0.5 ? 1 - (p - 0.5) * 5 : 1);
          }
          f2Opacity = Math.max(0, Math.min(1, f2Opacity));
          frame2.style.opacity = `${f2Opacity}`;
          let cardOffset = Math.max(0, 1 - (p - 0.2) * 3.33) * 100;
          card1.style.transform = `translateY(${-30 + cardOffset}px) rotate(${-cardOffset / 5}deg)`;
          card2.style.transform = `translateY(${30 + cardOffset}px) rotate(${cardOffset / 5}deg)`;
        }

        if (frame3) {
          let f3Opacity = p > 0.6 ? (p - 0.6) * 3.33 : 0;
          f3Opacity = Math.max(0, Math.min(1, f3Opacity));
          frame3.style.opacity = `${f3Opacity}`;
          frame3.style.transform = `scale(${1 + (1 - f3Opacity) * 3})`;
        }
      }

      // Horizontal Scroll
      if (horizontalSection && horizontalTrack) {
        const rect = horizontalSection.getBoundingClientRect();
        const ih = window.innerHeight;
        const scrollableDistance = rect.height - ih;
        let progress = 0;
        if (rect.top <= 0 && rect.bottom >= ih) {
          progress = Math.abs(rect.top) / scrollableDistance;
        } else if (rect.bottom < ih) {
          progress = 1;
        }
        const maxTranslate = -(document.body.clientWidth * 2.6);
        horizontalTrack.style.transform = `translate3d(${progress * maxTranslate}px, 0, 0)`;
      }

      // Follower Animation (desktop only)
      if (follower && !isTouchDevice) {
        followerX += (targetX - followerX) * 0.15;
        followerY += (targetY - followerY) * 0.15;
        follower.style.transform = `translate3d(${followerX}px, ${followerY}px, 0)`;
      }

      if (document.visibilityState === 'visible') requestAnimationFrame(render);
    }
    requestAnimationFrame(render);

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        requestAnimationFrame(render);
        if (particlesVisible) renderParticles();
      }
    });

    // --- YouTube IFrame API ---
    let player;
    let isMuted = true;
    const isMobile = window.innerWidth <= 768;

    if (!isMobile && !window.YT) {
      const tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      const firstScriptTag = document.getElementsByTagName('script')[0];
      firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
    }

    function initYTPlayer() {
      player = new YT.Player('hero-player', {
        videoId: 'vWi8L-jiYhc',
        playerVars: {
          autoplay: 1,
          mute: 1,
          loop: 1,
          playlist: 'vWi8L-jiYhc',
          controls: 0,
          rel: 0,
          modestbranding: 1,
          playsinline: 1,
          showinfo: 0,
          fs: 0,
          wmode: 'transparent',
          vq: 'hd2160'
        },
        events: {
          onReady: (e: any) => {
            e.target.setPlaybackQuality('hd2160');
          },
          onPlaybackQualityChange: (e: any) => {
            // Force back to highest if YouTube downgrades
            const q = e.target.getPlaybackQuality();
            if (q !== 'hd2160' && q !== 'hd1440' && q !== 'hd1080') {
              e.target.setPlaybackQuality('hd2160');
            }
          }
        }
      });
    }

    if (!isMobile) {
      if (window.YT && window.YT.Player) {
        initYTPlayer();
      } else {
        window.onYouTubeIframeAPIReady = initYTPlayer;
      }
    }

    // --- Unmute Button ---
    const unmuteBtn = document.getElementById('unmute-btn');
    const muteIcon = document.getElementById('mute-icon');
    const soundIcon = document.getElementById('sound-icon');

    function updateUnmuteBtn() {
      if (muteIcon && soundIcon) {
        if (isMuted) {
          muteIcon.classList.remove('hidden');
          soundIcon.classList.add('hidden');
        } else {
          muteIcon.classList.add('hidden');
          soundIcon.classList.remove('hidden');
        }
      }
    }

    if (unmuteBtn) {
      updateUnmuteBtn();
      unmuteBtn.addEventListener('click', () => {
        if (player) {
          if (isMuted) { player.unMute(); isMuted = false; }
          else { player.mute(); isMuted = true; }
          updateUnmuteBtn();
        }
      });
    }

    // --- Fullscreen Button ---
    const fullscreenBtn = document.getElementById('fullscreen-btn');
    if (fullscreenBtn) {
      fullscreenBtn.addEventListener('click', () => {
        if (player && player.getIframe) {
          const iframe = player.getIframe();
          if (iframe.requestFullscreen) iframe.requestFullscreen();
          else if (iframe.webkitRequestFullscreen) iframe.webkitRequestFullscreen();
          else if (iframe.webkitEnterFullscreen) iframe.webkitEnterFullscreen();
          if (player.unMute) player.unMute();
          if (player.setVolume) player.setVolume(100);
          isMuted = false;
          updateUnmuteBtn();
        }
      });
    }
  });
</script>

<style>
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-on-scroll.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes marquee {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-50%, 0, 0); }
  }
  .animate-marquee {
    animation: marquee 30s linear infinite;
    will-change: transform;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 0.85; }
  }

  @keyframes gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .animate-gradient {
    animation: gradient 6s ease infinite;
  }

  .cta-content {
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-content.cta-animate {
    opacity: 1;
    transform: translateY(0);
  }

  /* Hero Video Background */
  #hero-video-wrapper {
    background: #030303;
  }

  #hero-player {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    overflow: hidden;
  }

  #hero-player iframe {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    /* Exact 16:9 — always large enough to cover the full viewport */
    width: max(100vw, calc(100vh * 16 / 9));
    height: max(100vh, calc(100vw * 9 / 16));
  }

  #hero-video-wrapper .hero-video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(3,3,3,0.5) 0%, rgba(3,3,3,0.7) 50%, rgba(3,3,3,0.95) 100%);
    z-index: 1;
    pointer-events: auto;
    cursor: none !important;
  }

  @media (max-width: 768px) {
    #hero-video-wrapper,
    #hero-player {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) and (min-width: 769px) {
    #hero-video-wrapper {
      background-image: url('https://i.ytimg.com/vi/vWi8L-jiYhc/maxresdefault.jpg');
      background-size: cover;
      background-position: center;
    }
  }

  input:focus, textarea:focus {
    border-color: rgba(34, 211, 238, 0.5);
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.1);
  }

</style>
