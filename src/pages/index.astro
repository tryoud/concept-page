---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Nikolas Maerker | Web Developer & Creative" description="Freelancer für Webentwicklung, Videoproduktion und Drohnenaufnahmen — alles aus einer Hand.">
  
  {/* Background Glow Orbs */}
  <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] rounded-full bg-cyan-600/20 blur-[120px] mix-blend-screen opacity-70 animate-pulse"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[600px] h-[600px] rounded-full bg-violet-600/20 blur-[150px] mix-blend-screen opacity-70" style="animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;"></div>
      <div class="absolute top-[40%] left-[50%] -translate-x-1/2 w-[800px] h-[400px] rounded-[100%] bg-blue-900/10 blur-[120px]"></div>
    </div>

    {/* Hero Video Background */}
    <div id="hero-video-wrapper" class="fixed inset-0 -z-20">
      <div id="hero-player" class="w-full h-full"></div>
      <div class="hero-video-overlay"></div>
    </div>

    {/* Video Controls */}
    <div id="video-controls" class="fixed bottom-8 right-8 z-50 hidden md:flex gap-3">
      <button id="fullscreen-btn" class="w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white hover:bg-white/20 hover:scale-110 transition-all duration-300" aria-label="Video fullscreen">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>
      </button>
      <button id="unmute-btn" class="w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white hover:bg-white/20 hover:scale-110 transition-all duration-300" aria-label="Ton einschalten">
        <svg id="mute-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line></svg>
        <svg id="sound-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto hidden"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>
      </button>
    </div>

    <main class="relative z-10 font-sans">
      
      {/* Navigation */}
      <nav class="fixed top-0 w-full flex items-center justify-between px-4 py-3 sm:px-6 md:px-12 z-50 bg-black/80 backdrop-blur-md border-b border-white/5">
        <a href="#" class="flex items-center gap-2 group w-fit relative z-50">
          <img src="/favicon.svg" alt="NM" class="w-8 h-8 rounded-lg shadow-lg transition-transform group-hover:scale-105 group-hover:rotate-6" />
          <span class="text-lg sm:text-xl font-bold tracking-tight text-white/90">
            Nikolas Maerker
          </span>
        </a>
        
        {/* Desktop Nav */}
        <div class="hidden md:flex items-center gap-8">
          <a href="#services" class="text-sm text-zinc-400 hover:text-white transition-colors">Services</a>
          <a href="#work" class="text-sm text-zinc-400 hover:text-white transition-colors">Work</a>
          <a href="#about" class="text-sm text-zinc-400 hover:text-white transition-colors">About</a>
          <a href="#contact" class="px-5 py-2 text-sm font-semibold text-white transition-all bg-white/10 border border-white/20 rounded-full hover:bg-white/20 hover:scale-105">
            Kontakt
          </a>
        </div>
        
        {/* Mobile Menu Button */}
        <button id="mobile-menu-btn" class="md:hidden p-2 text-white/80 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
      </nav>
      
      {/* Mobile Menu */}
      <div id="mobile-menu" class="fixed inset-0 bg-black/95 z-40 hidden flex-col items-center justify-center gap-8 pt-20">
        <a href="#services" class="text-2xl font-bold text-white hover:text-cyan-400 transition-colors mobile-link">Services</a>
        <a href="#work" class="text-2xl font-bold text-white hover:text-cyan-400 transition-colors mobile-link">Work</a>
        <a href="#about" class="text-2xl font-bold text-white hover:text-cyan-400 transition-colors mobile-link">About</a>
        <a href="#contact" class="px-8 py-4 text-lg font-bold text-black bg-gradient-to-r from-cyan-400 to-violet-400 rounded-full mobile-link">Kontakt</a>
      </div>

      {/* Hero Section */}
      <section class="min-h-[100dvh] w-full flex flex-col justify-center items-center px-4 sm:px-6 pt-20 pb-12 md:pt-32 md:pb-20 lg:px-24 relative">
        <div class="w-full max-w-5xl mx-auto flex flex-col items-start text-left">
          
          <h1 class="text-3xl xs:text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black tracking-tight text-white leading-[1.1] max-w-5xl reveal-on-scroll">
            <span class="block">Websites und Content</span>
            <span class="block">für Dienstleister,</span>
            <span class="block">Unternehmen <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-blue-500 to-violet-500 bg-[length:200%_auto] animate-gradient">und Marken.</span></span>
          </h1>
          
          <p class="mt-6 sm:mt-8 text-base sm:text-lg md:text-xl text-zinc-400 max-w-2xl font-light leading-relaxed reveal-on-scroll">
            Web Design, Photo, Video und Drohnenaufnahmen — alles aus einer Hand.
          </p>
          
          <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-5 mt-8 sm:mt-12 w-fit reveal-on-scroll">
            <a href="#apple-journey" class="group relative inline-flex items-center justify-center gap-2 sm:gap-3 px-6 sm:px-8 py-3 sm:py-4 bg-white text-black font-bold rounded-full overflow-hidden transition-all hover:scale-[1.03] active:scale-[0.97] shadow-[0_0_40px_rgba(255,255,255,0.2)] text-sm sm:text-base">
              <span>Mehr erfahren</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 transition-transform group-hover:translate-x-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
            <a href="#contact" class="group px-6 sm:px-8 py-3 sm:py-4 text-white font-medium hover:text-cyan-400 transition-colors flex items-center gap-2 text-sm sm:text-base">
              Projekt starten 
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 -translate-y-1 transition-all group-hover:opacity-100 group-hover:translate-y-0 sm:w-4 sm:h-4"><path d="M12 5v14"></path><path d="m19 12-7 7-7-7"></path></svg>
            </a>
          </div>
        </div>
      </section>

      {/* Apple-Style Sticky Journey */}
      <section class="relative w-full h-[400vh] bg-black" id="apple-journey">
        <div class="sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden bg-black">
          {/* Abstract Background Expander */}
          <div class="absolute top-1/2 left-1/2 w-[200vw] h-[200vh] rounded-[50%] bg-gradient-to-tr from-cyan-600 to-violet-800 expand-bg-element z-0 shadow-[0_0_100px_rgba(6,182,212,0.8)] opacity-0 will-change-transform" style="transform: translate(-50%, -50%) scale(0.1)"></div>
          
          {/* Frame 1: Text */}
          <div class="absolute inset-0 flex items-center justify-center flex-col z-10 text-center frame-1 pointer-events-none will-change-transform">
            <h2 class="text-6xl md:text-8xl font-black text-white px-4 tracking-tighter">Alles aus<br/>einer Hand.</h2>
            <p class="text-xl text-cyan-300 mt-6 font-semibold uppercase tracking-widest">Scroll nach unten ↓</p>
          </div>

          {/* Frame 2: Services */}
          <div class="absolute inset-0 flex items-center justify-center z-20 frame-2 opacity-0 pointer-events-none will-change-transform">
            <div class="flex gap-4 md:gap-12 flex-col sm:flex-row">
              <div class="w-48 h-64 md:w-72 md:h-96 bg-white/10 backdrop-blur-sm md:backdrop-blur-3xl rounded-3xl border border-white/20 p-6 ui-card-1 flex flex-col justify-between shadow-2xl will-change-transform">
                 <div class="w-12 h-12 rounded-full bg-cyan-400/30"></div>
                 <div class="space-y-3">
                   <div class="h-4 bg-white/20 rounded-md w-full"></div>
                   <div class="h-4 bg-white/20 rounded-md w-3/4"></div>
                   <div class="h-4 bg-white/20 rounded-md w-1/2"></div>
                 </div>
              </div>
              <div class="w-48 h-64 md:w-72 md:h-96 bg-white/10 backdrop-blur-sm md:backdrop-blur-3xl rounded-3xl border border-white/20 p-6 ui-card-2 flex flex-col justify-between shadow-2xl will-change-transform">
                 <div class="w-full h-32 bg-violet-500/30 rounded-2xl"></div>
                 <div class="w-full h-12 rounded-full bg-white text-black font-bold flex items-center justify-center">Mehr</div>
              </div>
            </div>
          </div>

          {/* Frame 3: The ultimate reveal */}
          <div class="absolute inset-0 flex items-center justify-center z-30 frame-3 opacity-0 pointer-events-none will-change-transform">
             <h2 class="text-[clamp(3rem,10vw,12rem)] px-4 font-black text-white opacity-90 drop-shadow-[0_0_100px_rgba(255,255,255,1)] tracking-tighter uppercase whitespace-normal text-center">Fokussiert.</h2>
          </div>
        </div>
      </section>

      {/* Services Grid */}
      <section id="services" class="py-32 px-6 md:px-16 lg:px-24 w-full bg-zinc-950 relative z-40 shadow-[0_-50px_50px_rgba(0,0,0,0.8)]">
        <div class="max-w-7xl mx-auto">
          
          <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
            <div class="reveal-on-scroll">
              <span class="text-xs tracking-[0.3em] text-cyan-500 uppercase font-bold mb-4 block">Leistungen</span>
              <h2 class="text-3xl md:text-5xl font-bold tracking-tight">
                Was ich <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">mache.</span>
              </h2>
            </div>
            <p class="text-zinc-400 max-w-md reveal-on-scroll">
              Von der Konzeption bis zum Launch — alles aus einer Hand, effizient und fokussiert auf dein Ergebnis.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            
            {/* Web Design & Development */}
            <div class="tilt-card reveal-on-scroll group relative p-8 rounded-2xl bg-zinc-900/40 backdrop-blur-xl border border-white/5 transition-all duration-500 hover:bg-zinc-800/50 hover:border-cyan-500/30 hover:shadow-[0_0_40px_-10px_rgba(6,182,212,0.3)] min-h-[380px] flex flex-col" style="transform-style: preserve-3d;">
              <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
              <div class="relative z-10 transform-gpu flex flex-col h-full" style="transform: translateZ(30px);">
                <div class="w-14 h-14 rounded-2xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center mb-6 text-cyan-400 group-hover:scale-110 transition-transform duration-500">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
                </div>
                <span class="text-5xl font-black text-white/5 mb-4">01</span>
                <h3 class="text-2xl font-bold text-white mb-4">Websites & Landing Pages</h3>
                <p class="text-zinc-400 font-light leading-relaxed mb-6 flex-grow">
                  Performante Websites, die deine Leistung verständlich machen und auf Anfragen ausgerichtet sind.
                </p>
                <ul class="space-y-3 text-sm text-zinc-500">
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
                    Positionierung & UX-Strategie
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
                    SEO & Performance-Optimierung
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
                    Astro, WordPress, Cloudflare
                  </li>
                </ul>
              </div>
            </div>

            {/* Photo & Video */}
            <div class="tilt-card reveal-on-scroll group relative p-8 rounded-2xl bg-zinc-900/40 backdrop-blur-xl border border-white/5 transition-all duration-500 hover:bg-zinc-800/50 hover:border-violet-500/30 hover:shadow-[0_0_40px_-10px_rgba(139,92,246,0.3)] min-h-[380px] flex flex-col" style="transform-style: preserve-3d;">
              <div class="absolute inset-0 bg-gradient-to-br from-violet-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
              <div class="relative z-10 transform-gpu flex flex-col h-full" style="transform: translateZ(30px);">
                <div class="w-14 h-14 rounded-2xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center mb-6 text-violet-400 group-hover:scale-110 transition-transform duration-500">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>
                </div>
                <span class="text-5xl font-black text-white/5 mb-4">02</span>
                <h3 class="text-2xl font-bold text-white mb-4">Photo & Video</h3>
                <p class="text-zinc-400 font-light leading-relaxed mb-6 flex-grow">
                  Foto- und Videocontent, der deine Marke hochwertig zeigt — für Website, Social Media und Kampagnen.
                </p>
                <ul class="space-y-3 text-sm text-zinc-500">
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-violet-500"></span>
                    Event-, Portrait- & Redaktionsfotografie
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-violet-500"></span>
                    Videoproduktion & Videoschnitt
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-violet-500"></span>
                    Einheitlicher Look für alle Kanäle
                  </li>
                </ul>
              </div>
            </div>

            {/* Drone / Aerial */}
            <div class="tilt-card reveal-on-scroll group relative p-8 rounded-2xl bg-zinc-900/40 backdrop-blur-xl border border-white/5 transition-all duration-500 hover:bg-zinc-800/50 hover:border-amber-500/30 hover:shadow-[0_0_40px_-10px_rgba(245,158,11,0.3)] min-h-[380px] flex flex-col" style="transform-style: preserve-3d;">
              <div class="absolute inset-0 bg-gradient-to-br from-amber-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
              <div class="relative z-10 transform-gpu flex flex-col h-full" style="transform: translateZ(30px);">
                <div class="w-14 h-14 rounded-2xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center mb-6 text-amber-400 group-hover:scale-110 transition-transform duration-500">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8"/><path d="m5 12-2-2 2-2"/><path d="m19 12 2-2-2-2"/><path d="m5 16-2 2 2 2"/><path d="m19 16 2 2-2 2"/><circle cx="12" cy="5" r="3"/></svg>
                </div>
                <span class="text-5xl font-black text-white/5 mb-4">03</span>
                <h3 class="text-2xl font-bold text-white mb-4">Drohne & Aerial</h3>
                <p class="text-zinc-400 font-light leading-relaxed mb-6 flex-grow">
                  Lizenzierte Drohnenaufnahmen für Immobilien, Events und Markencontent. Filmische Shots.
                </p>
                <ul class="space-y-3 text-sm text-zinc-500">
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                    Lizenzierte Luftaufnahmen
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                    Immobilien, Events & Unternehmen
                  </li>
                  <li class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                    Ruhige, filmische Shots
                  </li>
                </ul>
              </div>
            </div>
            
          </div>
        </div>
      </section>

      {/* Expertise Section */}
      <section class="py-24 w-full bg-zinc-950 relative z-40 overflow-hidden" id="about">
        <div class="max-w-7xl mx-auto px-6 md:px-16 lg:px-24 mb-16">
          <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 reveal-on-scroll">
            <div>
              <span class="text-xs tracking-[0.3em] text-cyan-500 uppercase font-bold mb-4 block">Expertise</span>
              <h2 class="text-3xl md:text-5xl font-bold tracking-tight">
                Drei Bereiche,<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">eine Vision.</span>
              </h2>
            </div>
            <p class="text-zinc-400 max-w-md">
              Von der Code-Zeile bis zum finalen Shot — ich verbinde Technik und Kreativität für Ergebnisse, die überzeugen.
            </p>
          </div>
        </div>
        
        <div class="w-full flex flex-col relative" id="reveal-list">
          <div id="hover-follower" class="fixed top-0 left-0 w-0 h-0 pointer-events-none z-[45] will-change-transform hidden [@media(pointer:fine)]:block">
             <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[500px] aspect-[4/3] overflow-hidden pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] scale-50 opacity-0" id="reveal-img-01">
                <div class="w-full h-full bg-[url('https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center"></div>
             </div>
             <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[500px] aspect-[4/3] overflow-hidden pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] scale-50 opacity-0" id="reveal-img-02">
                <div class="w-full h-full bg-[url('/expertise-content.jpg')] bg-cover bg-center"></div>
             </div>
             <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[500px] aspect-[4/3] overflow-hidden pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] scale-50 opacity-0" id="reveal-img-03">
                <div class="w-full h-full bg-[url('https://images.unsplash.com/photo-1484480974693-6ca0a78fb36b?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center"></div>
             </div>
          </div>
          
          {[
            { title: 'Code', id: '01', desc: 'Performante Architekturen mit Astro, WordPress & Cloudflare', color: 'cyan' },
            { title: 'Content', id: '02', desc: 'Event-Fotografie, Drohnenaufnahmen und Videoschnitt', color: 'violet' },
            { title: 'Prozess', id: '03', desc: 'Klarer Ablauf: Briefing, Konzeption, Umsetzung, Launch', color: 'amber' }
          ].map(item => (
            <div class="hover-reveal-row relative border-t border-white/5 last:border-b group md:cursor-none" data-id={item.id}>
              {/* Mobile: colored left border accent */}
              <div class={`md:hidden absolute left-0 top-0 bottom-0 w-1 rounded-r-full ${item.color === 'cyan' ? 'bg-cyan-500/50' : item.color === 'violet' ? 'bg-violet-500/50' : 'bg-amber-500/50'}`}></div>
              <div class="max-w-7xl mx-auto px-6 md:px-16 lg:px-24 py-8 md:py-16 flex flex-col md:flex-row md:justify-between md:items-center relative z-50 transition-colors duration-500 group-hover:text-white">
                <div class="pointer-events-none">
                  <div class="flex items-center gap-3 mb-2">
                    <h3 class="text-4xl md:text-8xl lg:text-9xl font-black uppercase tracking-tighter mix-blend-difference">{item.title}</h3>
                    <span class={`md:hidden text-xs font-bold tracking-widest px-2 py-0.5 rounded-full border ${item.color === 'cyan' ? 'text-cyan-400 border-cyan-500/40 bg-cyan-500/10' : item.color === 'violet' ? 'text-violet-400 border-violet-500/40 bg-violet-500/10' : 'text-amber-400 border-amber-500/40 bg-amber-500/10'}`}>{item.id}</span>
                  </div>
                  <p class={`text-sm md:text-2xl font-light mt-1 md:mt-2 md:text-zinc-500 mix-blend-difference opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity translate-y-0 md:translate-y-4 md:group-hover:translate-y-0 duration-500 ${item.color === 'cyan' ? 'text-cyan-300/70' : item.color === 'violet' ? 'text-violet-300/70' : 'text-amber-300/70'}`}>{item.desc}</p>
                </div>
                <span class={`text-xl md:text-3xl font-light opacity-30 group-hover:opacity-100 transition-opacity pointer-events-none hidden md:block ${item.color === 'cyan' ? 'group-hover:text-cyan-400' : item.color === 'violet' ? 'group-hover:text-violet-400' : 'group-hover:text-amber-400'}`}>{item.id}</span>
              </div>
              <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-all duration-[600ms] z-0 scale-x-0 group-hover:scale-x-100 origin-left ${
