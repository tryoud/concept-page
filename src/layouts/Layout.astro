---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = 'Nikolas Maerker — Freelancer für Webentwicklung, Videoproduktion und Drohnenaufnahmen.',
  lang = 'de',
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <meta name="description" content={description} />
    <ViewTransitions />
	</head>
	<body class="bg-[#030303] text-zinc-100 antialiased overflow-x-hidden selection:bg-cyan-500/30 selection:text-cyan-200">
		
		{/* Noise Overlay */}
		<div class="pointer-events-none fixed inset-0 z-50 w-full h-full opacity-30 mix-blend-overlay" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E&quot;);"></div>
		
		{/* Custom Cursor — starts invisible, no position until first mousemove */}
		<div transition:persist id="magic-cursor" class="hidden md:block pointer-events-none fixed top-0 left-0 w-6 h-6 rounded-full bg-cyan-400 mix-blend-screen shadow-[0_0_25px_rgba(34,211,238,0.9)] z-[9999] opacity-0 backdrop-blur-sm" style="transform: translate3d(-100px,-100px,0)">
		</div>

		<slot />

		<script>
      document.addEventListener('astro:page-load', () => {
        const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);
        if (isTouchDevice) return;

        const cursor = document.getElementById('magic-cursor');
        if (!cursor) return;

        // Always reset to invisible on each page load (handles View Transitions)
        cursor.style.transition = 'none';
        cursor.style.opacity = '0';
        cursor.style.transform = 'translate3d(-100px,-100px,0)';

        let mouseX = -100;
        let mouseY = -100;
        let cursorX = -100;
        let cursorY = -100;
        let isHovering = false;
        let hasEntered = false;

        // Snap to real position on first entry, then smooth-follow
        document.addEventListener('mousemove', (e) => {
          if (!hasEntered) {
            // First move: teleport cursor to exact position instantly
            cursorX = e.clientX;
            cursorY = e.clientY;
            hasEntered = true;
            cursor.style.transition = 'opacity 0.2s ease';
            cursor.style.opacity = '0.8';
          }
          mouseX = e.clientX;
          mouseY = e.clientY;
        }, { passive: true });

        // Hide cursor when mouse leaves the window
        document.addEventListener('mouseleave', () => {
          cursor.style.opacity = '0';
          hasEntered = false;
        });
        document.addEventListener('mouseenter', () => {
          if (hasEntered) cursor.style.opacity = isHovering ? '1' : '0.8';
        });

        document.addEventListener('mouseover', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('a, button, [role="button"], .cursor-hover')) {
            isHovering = true;
          }
        });

        document.addEventListener('mouseout', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('a, button, [role="button"], .cursor-hover')) {
            isHovering = false;
          }
        });

        const render = () => {
          cursorX += (mouseX - cursorX) * 0.15;
          cursorY += (mouseY - cursorY) * 0.15;

          const size = isHovering ? 48 : 24;
          cursor.style.width = `${size}px`;
          cursor.style.height = `${size}px`;
          cursor.style.transform = `translate3d(${cursorX - size/2}px, ${cursorY - size/2}px, 0)`;
          if (hasEntered) {
            cursor.style.opacity = isHovering ? '1' : '0.8';
          }

          requestAnimationFrame(render);
        };
        requestAnimationFrame(render);
      });
		</script>
	</body>
</html>

<style is:global>
  :root {
    --bg-color: #030303;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    background-color: var(--bg-color);
  }
  
/* Hide the default cursor everywhere for mouse users */
  @media (pointer: fine) {
    html, html body, html *, html *::before, html *::after,
    html *:hover, html *:focus, html *:active,
    #video-controls, #video-controls * {
      cursor: none !important;
    }
  }

 	html.dark body {
 		background-color: #030303 !important;
 		color: #f4f4f5 !important;
 	}
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
  
  /* Fallback for interactables transition when mouse leaves */
  a, button, .magnetic {
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
</style>
