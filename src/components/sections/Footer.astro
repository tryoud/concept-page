---
interface Props {
  lang?: string;
}
const { lang = 'de' } = Astro.props;
const isEn = lang === 'en';
const year = new Date().getFullYear();
---

<footer class="py-8 text-center text-zinc-600 text-sm border-t border-white/5 reveal-on-scroll bg-[#030303]">
  <p>© {year} Nikolas Maerker. <span data-i18n="footer.rights">{isEn ? 'All rights reserved.' : 'Alle Rechte vorbehalten.'}</span></p>
  <div class="mt-3 flex justify-center gap-6">
    <a href="/imprint" class="hover:text-zinc-400 transition-colors" data-i18n="footer.imprint">{isEn ? 'Imprint' : 'Impressum'}</a>
    <a href="/privacy" class="hover:text-zinc-400 transition-colors" data-i18n="footer.privacy">{isEn ? 'Privacy' : 'Datenschutz'}</a>
  </div>
</footer>