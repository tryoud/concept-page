---
interface Props {
  lang?: string;
}
const { lang = 'de' } = Astro.props;
const isEn = lang === 'en';
---

<section class="py-24 w-full bg-zinc-950 relative z-40 overflow-hidden" id="expertise">
  <div class="max-w-7xl mx-auto px-6 md:px-16 lg:px-24 mb-16">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 reveal-on-scroll">
      <div>
        <span class="text-xs tracking-[0.3em] text-cyan-500 uppercase font-bold mb-4 block" data-i18n="expertise.eyebrow">{isEn ? 'Expertise' : 'Expertise'}</span>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight">
          <span data-i18n="expertise.headingPrefix">{isEn ? 'Three disciplines,' : 'Drei Bereiche,'}</span><br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400" data-i18n="expertise.headingAccent">{isEn ? 'one vision.' : 'eine Vision.'}</span>
        </h2>
      </div>
      <p class="text-zinc-400 max-w-md" data-i18n="expertise.subline">
        {isEn ? 'From the first line of code to the final shot — I combine technology and creativity for results that convince.' : 'Von der Code-Zeile bis zum finalen Shot — ich verbinde Technik und Kreativität für Ergebnisse, die überzeugen.'}
      </p>
    </div>
  </div>
  
  <div class="w-full flex flex-col relative" id="reveal-list">
    {[
      { key: 'code', title: 'Code', id: '01', desc: isEn ? 'High-performance architectures with Astro, WordPress & Cloudflare' : 'Performante Architekturen mit Astro, WordPress & Cloudflare', color: 'cyan' },
      { key: 'content', title: 'Content', id: '02', desc: isEn ? 'Event photography, drone footage, and video editing' : 'Event-Fotografie, Drohnenaufnahmen und Videoschnitt', color: 'violet' },
      { key: 'process', title: 'Process', id: '03', desc: isEn ? 'Clear workflow: briefing, concept, implementation, launch' : 'Klarer Ablauf: Briefing, Konzeption, Umsetzung, Launch', color: 'amber' }
    ].map(item => (
      <div class="hover-reveal-row relative border-t border-white/5 last:border-b group md:cursor-none" data-id={item.id}>
        <div class={`md:hidden absolute left-0 top-0 bottom-0 w-1 rounded-r-full ${item.color === 'cyan' ? 'bg-cyan-500/50' : item.color === 'violet' ? 'bg-violet-500/50' : 'bg-amber-500/50'}`}></div>
        <div class="max-w-7xl mx-auto px-6 md:px-16 lg:px-24 py-8 md:py-16 flex flex-col md:flex-row md:justify-between md:items-center relative z-50 transition-colors duration-500 group-hover:text-white">
          <div class="pointer-events-none">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="text-4xl md:text-8xl lg:text-9xl font-black uppercase tracking-tighter mix-blend-difference" data-i18n={`expertise.rows.${item.key}.title`}>{item.title}</h3>
              <span class={`md:hidden text-xs font-bold tracking-widest px-2 py-0.5 rounded-full border ${item.color === 'cyan' ? 'text-cyan-400 border-cyan-500/40 bg-cyan-500/10' : item.color === 'violet' ? 'text-violet-400 border-violet-500/40 bg-violet-500/10' : 'text-amber-400 border-amber-500/40 bg-amber-500/10'}`}>{item.id}</span>
            </div>
            <p class={`text-sm md:text-2xl font-light mt-1 md:mt-2 md:text-zinc-500 mix-blend-difference opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity translate-y-0 md:translate-y-4 md:group-hover:translate-y-0 duration-500 ${item.color === 'cyan' ? 'text-cyan-300/70' : item.color === 'violet' ? 'text-violet-300/70' : 'text-amber-300/70'}`} data-i18n={`expertise.rows.${item.key}.desc`}>{item.desc}</p>
          </div>
          <span class={`text-xl md:text-3xl font-light opacity-30 group-hover:opacity-100 transition-opacity pointer-events-none hidden md:block ${item.color === 'cyan' ? 'group-hover:text-cyan-400' : item.color === 'violet' ? 'group-hover:text-violet-400' : 'group-hover:text-amber-400'}`}>{item.id}</span>
        </div>
        <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-all duration-[600ms] z-0 scale-x-0 group-hover:scale-x-100 origin-left ${
          item.color === 'cyan' ? 'bg-gradient-to-r from-cyan-950/80 to-transparent' :
          item.color === 'violet' ? 'bg-gradient-to-r from-violet-950/80 to-transparent' :
          'bg-gradient-to-r from-amber-950/80 to-transparent'
        }`}></div>
      </div>
    ))}
  </div>
</section>

<!-- Hover Follower Images -->
<div id="hover-follower" class="fixed top-0 left-0 w-0 h-0 pointer-events-none z-[60] will-change-transform hidden [@media(pointer:fine)]:block">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[500px] aspect-[4/3] overflow-hidden pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] scale-50 opacity-0" id="reveal-img-01">
    <div class="w-full h-full bg-[url('https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center"></div>
  </div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[500px] aspect-[4/3] overflow-hidden pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] scale-50 opacity-0" id="reveal-img-02">
    <div class="w-full h-full bg-[url('/expertise-content.jpg')] bg-cover bg-center"></div>
  </div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[500px] aspect-[4/3] overflow-hidden pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] scale-50 opacity-0" id="reveal-img-03">
    <div class="w-full h-full bg-[url('https://images.unsplash.com/photo-1484480974693-6ca0a78fb36b?q=80&w=1200&auto=format&fit=crop')] bg-cover bg-center"></div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouchDevice = ('ontouchstart' in window) || navigator.maxTouchPoints > 0;
    
    const revealRows = document.querySelectorAll('.hover-reveal-row');
    const follower = document.getElementById('hover-follower');
    
    let followerX = window.innerWidth / 2;
    let followerY = window.innerHeight / 2;
    let targetX = followerX;
    let targetY = followerY;
    let isTracking = false;

    if (follower && !isTouchDevice && !prefersReducedMotion) {
      document.addEventListener('mousemove', (e) => {
        targetX = e.clientX;
        targetY = e.clientY;
        if (!isTracking) {
          followerX = targetX;
          followerY = targetY;
          isTracking = true;
        }
      });

      revealRows.forEach(row => {
        row.addEventListener('mouseenter', () => {
          const rowId = row.getAttribute('data-id');
          document.querySelectorAll('[id^="reveal-img-"]').forEach(el => {
            el.style.opacity = '0';
            el.style.transform = 'translate(-50%, -50%) scale(0.5) rotate(0deg)';
          });
          if (rowId) {
            const activeImg = document.getElementById(`reveal-img-${rowId}`);
            if (activeImg) {
              activeImg.style.opacity = '1';
              activeImg.style.transform = `translate(-50%, -50%) scale(1) rotate(${(Math.random() - 0.5) * 6}deg)`;
            }
          }
        });
        row.addEventListener('mouseleave', () => {
          const rowId = row.getAttribute('data-id');
          if (rowId) {
            const activeImg = document.getElementById(`reveal-img-${rowId}`);
            if (activeImg) {
              activeImg.style.opacity = '0';
              activeImg.style.transform = 'translate(-50%, -50%) scale(0.5) rotate(0deg)';
            }
          }
        });
      });
      
      function animateFollower() {
        followerX += (targetX - followerX) * 0.15;
        followerY += (targetY - followerY) * 0.15;
        follower.style.transform = `translate3d(${followerX}px, ${followerY}px, 0)`;
        requestAnimationFrame(animateFollower);
      }
      animateFollower();
    }
  });
</script>