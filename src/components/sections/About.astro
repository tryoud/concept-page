---
const { about } = Astro.props;

const headline = about?.headline ?? "How I work";
const subline = about?.subline ?? "";
const paragraphs = about?.paragraphs ?? [];
const process = about?.process ?? [];
---

<section id="about" class="border-t border-black/10">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight text-black sm:text-3xl">
        {headline}
      </h2>
      {subline && (
        <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
          {subline}
        </p>
      )}
    </div>

    <div class="mt-10 grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-6">
        {paragraphs.map((para) => (
          <p class="mt-4 text-sm leading-relaxed text-black/75 sm:text-base">
            {para}
          </p>
        ))}
      </div>

      <div class="lg:col-span-6">
        <div class="rounded-3xl border border-black/10 bg-white p-6">
          <div class="text-xs font-medium uppercase tracking-wide text-black/50">
            Process
          </div>
          <ol class="mt-5 grid gap-4">
            {process.map((step, idx) => (
              <li class="rounded-2xl border border-black/10 p-4">
                <div class="flex items-center gap-3">
                  <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-black text-xs font-semibold text-white">
                    {idx + 1}
                  </span>
                  <div class="text-sm font-semibold text-black">
                    {step.title}
                  </div>
                </div>
                <p class="mt-2 text-sm text-black/70">{step.details}</p>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>
