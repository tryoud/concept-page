---
const { contact } = Astro.props;

const headline = contact?.headline ?? "Contact";
const subline = contact?.subline ?? "";
const email = contact?.email ?? "";
const social = contact?.social ?? [];

const endpoint = contact?.form?.endpoint ?? "";
const honeypotFieldName = contact?.form?.honeypotFieldName ?? "company";

const needsEndpoint = !endpoint || endpoint.includes("REPLACE_ME");
---

<section id="contact" class="border-t border-black/10">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight text-black sm:text-3xl">
        {headline}
      </h2>
      {subline && (
        <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
          {subline}
        </p>
      )}
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <div class="rounded-3xl border border-black/10 bg-white p-6">
          <div class="text-sm font-semibold text-black">Email</div>
          {email ? (
            <a
              class="mt-2 inline-block text-sm text-black/70 underline hover:text-black"
              href={`mailto:${email}`}
            >
              {email}
            </a>
          ) : (
            <p class="mt-2 text-sm text-black/60">Add an email in content/site.json.</p>
          )}

          {(social?.length ?? 0) > 0 && (
            <div class="mt-8">
              <div class="text-sm font-semibold text-black">Social</div>
              <ul class="mt-3 grid gap-2">
                {social.map((s) => (
                  <li>
                    <a
                      class="text-sm text-black/70 underline hover:text-black"
                      href={s.href}
                      target="_blank"
                      rel="noreferrer"
                    >
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>

      <div class="lg:col-span-7">
        <form
          class="rounded-3xl border border-black/10 bg-white p-6"
          method="POST"
          action={endpoint}
        >
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="grid gap-2">
              <span class="text-sm font-medium text-black">Name</span>
              <input
                class="h-11 rounded-xl border border-black/10 bg-white px-3 text-sm outline-none focus:border-black/30"
                name="name"
                required
                autocomplete="name"
              />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-medium text-black">Email</span>
              <input
                class="h-11 rounded-xl border border-black/10 bg-white px-3 text-sm outline-none focus:border-black/30"
                type="email"
                name="email"
                required
                autocomplete="email"
              />
            </label>

            <label class="grid gap-2 sm:col-span-2">
              <span class="text-sm font-medium text-black">Message</span>
              <textarea
                class="min-h-[140px] rounded-xl border border-black/10 bg-white px-3 py-2 text-sm outline-none focus:border-black/30"
                name="message"
                required
              ></textarea>
            </label>

            <!-- Honeypot (spam trap) -->
            <div class="hidden">
              <label>
                Don’t fill this out:
                <input name={honeypotFieldName} tabindex="-1" autocomplete="off" />
              </label>
            </div>
          </div>

          <div class="mt-6 flex items-center justify-between gap-4">
            <p class="text-xs text-black/50">
              By sending this, you agree that I can reply to your message.
            </p>
            <button
              class="inline-flex items-center justify-center rounded-xl bg-black px-5 py-2.5 text-sm font-medium text-white hover:bg-black/90"
              type="submit"
            >
              Send
            </button>
          </div>
        </form>

        {needsEndpoint && (
          <p class="mt-3 text-xs text-black/50">
            Note: Replace the Formspree endpoint in{" "}
            <code class="rounded bg-black/[0.03] px-1.5 py-0.5">content/site.json</code>.
          </p>
        )}
      </div>
    </div>
  </div>
</section>
