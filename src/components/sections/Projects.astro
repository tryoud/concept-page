---
const { projects } = Astro.props;

const headline = projects?.headline ?? "Projects";
const subline = projects?.subline ?? "";
const items = projects?.items ?? [];
---

<section id="projects" class="border-t border-black/10">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight text-black sm:text-3xl">
        {headline}
      </h2>
      {subline && (
        <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
          {subline}
        </p>
      )}
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {items.map((p) => (
        <a
          class="group rounded-3xl border border-black/10 bg-white p-6 transition hover:bg-black/[0.02]"
          href={p.href}
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-lg font-semibold text-black group-hover:underline">
                {p.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-black/70">
                {p.description}
              </p>
            </div>
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-black/10 bg-white text-black/70">
              →
            </span>
          </div>

          {(p.stack?.length ?? 0) > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {p.stack.map((s) => (
                <span class="rounded-full border border-black/10 bg-black/[0.02] px-2.5 py-1 text-xs text-black/70">
                  {s}
                </span>
              ))}
            </div>
          )}

          {(p.outcomes?.length ?? 0) > 0 && (
            <ul class="mt-5 grid gap-2">
              {p.outcomes.slice(0, 3).map((o) => (
                <li class="text-sm text-black/75">• {o}</li>
              ))}
            </ul>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
