---
const { stack } = Astro.props;

const headline = stack?.headline ?? "Tech Stack";
const subline = stack?.subline ?? "";
const groups = stack?.groups ?? [];
---

<section id="stack" class="border-t border-black/10">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight text-black sm:text-3xl">
        {headline}
      </h2>
      {subline && (
        <p class="mt-3 text-sm leading-relaxed text-black/70 sm:text-base">
          {subline}
        </p>
      )}
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {groups.map((group) => (
        <div class="rounded-3xl border border-black/10 bg-white p-6">
          <h3 class="text-lg font-semibold text-black">{group.title}</h3>

          <ul class="mt-5 grid gap-3">
            {(group.items ?? []).map((tool) => (
              <li class="rounded-2xl border border-black/10 p-4">
                <div class="text-sm font-semibold text-black">{tool.name}</div>
                {(tool.tags?.length ?? 0) > 0 && (
                  <div class="mt-2 flex flex-wrap gap-2">
                    {tool.tags.map((t) => (
                      <span class="rounded-full border border-black/10 bg-black/[0.02] px-2.5 py-1 text-xs text-black/70">
                        {t}
                      </span>
                    ))}
                  </div>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
