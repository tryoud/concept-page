---
const { hero } = Astro.props;

const headline = hero?.headline ?? "Fast, SEO-ready websites—built to convert.";
const subline = hero?.subline ?? "";
const ctas = hero?.ctas ?? [];
const highlights = hero?.highlights ?? [];
---

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
  <div class="grid gap-10 md:grid-cols-12 md:items-center">
    <div class="md:col-span-7">
      <h1 class="text-4xl font-semibold tracking-tight text-black sm:text-5xl">
        {headline}
      </h1>

      {subline && (
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-black/70 sm:text-lg">
          {subline}
        </p>
      )}

      {(ctas?.length ?? 0) > 0 && (
        <div class="mt-8 flex flex-wrap gap-3">
          {ctas.map((cta) => {
            const isPrimary = cta.variant === "primary";
            const base =
              "inline-flex items-center justify-center rounded-xl px-5 py-2.5 text-sm font-medium transition";
            const primary = "bg-black text-white hover:bg-black/90";
            const outline = "border border-black/15 bg-white text-black hover:bg-black/5";
            return (
              <a class={`${base} ${isPrimary ? primary : outline}`} href={cta.href}>
                {cta.label}
              </a>
            );
          })}
        </div>
      )}

      {(highlights?.length ?? 0) > 0 && (
        <ul class="mt-10 grid gap-3 sm:grid-cols-2">
          {highlights.map((h) => (
            <li class="flex items-start gap-3 rounded-2xl border border-black/10 bg-white p-4">
              <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-lg bg-black text-xs font-semibold text-white">
                ✓
              </span>
              <span class="text-sm text-black/75">{h}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <div class="md:col-span-5">
      <div class="rounded-3xl border border-black/10 bg-gradient-to-b from-black/[0.03] to-black/[0.01] p-6">
        <div class="text-xs font-medium uppercase tracking-wide text-black/50">
          Snapshot
        </div>
        <div class="mt-4 space-y-4">
          <div class="rounded-2xl border border-black/10 bg-white p-4">
            <div class="text-sm font-semibold text-black">Stack</div>
            <div class="mt-1 text-sm text-black/70">Astro · Tailwind · Cloudflare Pages</div>
          </div>
          <div class="rounded-2xl border border-black/10 bg-white p-4">
            <div class="text-sm font-semibold text-black">Focus</div>
            <div class="mt-1 text-sm text-black/70">
              Performance, SEO, clean UI, maintainable content.
            </div>
          </div>
          <div class="rounded-2xl border border-black/10 bg-white p-4">
            <div class="text-sm font-semibold text-black">Work</div>
            <div class="mt-1 text-sm text-black/70">
              Websites, landing pages, CMS structuring, automations.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
