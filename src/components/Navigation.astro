---
interface Props {
  lang?: string;
}

const { lang = 'de' } = Astro.props;
const isEn = lang === 'en';
---

<nav class="fixed top-0 w-full flex items-center justify-between px-4 py-3 sm:px-6 md:px-12 z-50 bg-black/80 backdrop-blur-md border-b border-white/5">
  <a href="/" class="flex items-center gap-2 group w-fit relative z-50">
    <img src="/favicon.svg" alt="NM" class="w-8 h-8 rounded-lg shadow-lg transition-transform group-hover:scale-105 group-hover:rotate-6" />
    <span class="text-lg sm:text-xl font-bold tracking-tight text-white/90">Nikolas Maerker</span>
  </a>
  
  <!-- Desktop Nav -->
  <div class="hidden md:flex items-center gap-8">
    <a href="#services" class="text-sm text-zinc-400 hover:text-white transition-colors" data-i18n="nav.services">{isEn ? 'Services' : 'Services'}</a>
    <a href="#expertise" class="text-sm text-zinc-400 hover:text-white transition-colors" data-i18n="nav.expertise">{isEn ? 'Expertise' : 'Expertise'}</a>
    <a href="#work" class="text-sm text-zinc-400 hover:text-white transition-colors" data-i18n="nav.work">{isEn ? 'Work' : 'Work'}</a>
    <a href="#process" class="text-sm text-zinc-400 hover:text-white transition-colors" data-i18n="nav.process">{isEn ? 'Process' : 'Prozess'}</a>
    <a href="#contact" class="px-5 py-2 text-sm font-semibold text-white transition-all bg-white/10 border border-white/20 rounded-full hover:bg-white/20 hover:scale-105" data-i18n="nav.contact">{isEn ? 'Contact' : 'Kontakt'}</a>
    <div class="flex items-center gap-1 rounded-full border border-white/10 bg-white/5 p-1" aria-label="Sprachauswahl">
      <button type="button" class="language-switcher rounded-full px-2.5 py-1 text-xs font-semibold transition-colors hover:bg-white/10" data-lang-switch="de" aria-label="Deutsch" aria-pressed={!isEn}>DE</button>
      <button type="button" class="language-switcher rounded-full px-2.5 py-1 text-xs font-semibold transition-colors hover:bg-white/10" data-lang-switch="en" aria-label="English" aria-pressed={isEn}>EN</button>
    </div>
  </div>
  
  <!-- Mobile Menu Button -->
  <button id="mobile-menu-btn" class="md:hidden p-2 text-white/80 hover:text-white" aria-label="Menü öffnen">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
  </button>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 bg-black/95 z-40 hidden flex-col items-center justify-center gap-8 pt-20">
  <a href="#services" class="text-2xl font-bold text-white hover:text-cyan-400 transition-colors mobile-link" data-i18n="nav.services">{isEn ? 'Services' : 'Services'}</a>
  <a href="#expertise" class="text-2xl font-bold text-white hover:text-cyan-400 transition-colors mobile-link" data-i18n="nav.expertise">{isEn ? 'Expertise' : 'Expertise'}</a>
  <a href="#work" class="text-2xl font-bold text-white hover:text-cyan-400 transition-colors mobile-link" data-i18n="nav.work">{isEn ? 'Work' : 'Work'}</a>
  <a href="#process" class="text-2xl font-bold text-white hover:text-cyan-400 transition-colors mobile-link" data-i18n="nav.process">{isEn ? 'Process' : 'Prozess'}</a>
  <a href="#contact" class="px-8 py-4 text-lg font-bold text-black bg-gradient-to-r from-cyan-400 to-violet-400 rounded-full mobile-link" data-i18n="nav.contact">{isEn ? 'Contact' : 'Kontakt'}</a>
  <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/5 p-1" aria-label="Sprachauswahl">
    <button type="button" class="language-switcher rounded-full px-4 py-2 text-sm font-semibold transition-colors hover:bg-white/10 mobile-link" data-lang-switch="de" aria-label="Deutsch" aria-pressed={!isEn}>DE</button>
    <button type="button" class="language-switcher rounded-full px-4 py-2 text-sm font-semibold transition-colors hover:bg-white/10 mobile-link" data-lang-switch="en" aria-label="English" aria-pressed={isEn}>EN</button>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    
    if (mobileMenuBtn && mobileMenu) {
      let menuOpen = false;
      mobileMenuBtn.addEventListener('click', () => {
        menuOpen = !menuOpen;
        if (menuOpen) {
          mobileMenu.classList.remove('hidden');
          mobileMenu.classList.add('flex');
          document.body.style.overflow = 'hidden';
        } else {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
          document.body.style.overflow = '';
        }
      });
      
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          menuOpen = false;
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
          document.body.style.overflow = '';
        });
      });
    }
  });
</script>